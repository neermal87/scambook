# MySQL (AWS RDS: set host to your RDS endpoint)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=scambook
DB_PORT=3306

# JWT — use a long random string in production
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# Server
PORT=3000

# Public URL base for links (optional; EC2/LB URL or domain)
# Used when constructing absolute image URLs for APIs if needed
PUBLIC_BASE_URL=http://localhost:3000
